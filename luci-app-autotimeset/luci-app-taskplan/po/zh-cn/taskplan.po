msgid "1-8 is the continuous time from 1-8 clock; 11,12,16 clock are discontinuous; */3 represents every 3 hours; * every hour."
msgstr "1-8是从1点到8点的连续时间；11、12、16点钟不连续；*/3表示每3小时一次；*每小时。"

msgid "Minute(0~59)"
msgstr "分钟(0~59)"

msgid "1-30 is continuous 1-30 minutes; 7,8,9 minutes discontinuous ; */5 means every 5 minutes ; * every minutes."
msgstr "1-30是连续的1-30分钟；7,8,9分钟不连续；*/5表示每5分钟一次；*每分钟。"

